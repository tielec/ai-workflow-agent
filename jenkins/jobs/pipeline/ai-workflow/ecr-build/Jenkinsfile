/**
 * AI Workflow - ECR Image Build & Push (Multi-arch)
 *
 * ECRへのマルチアーキDockerイメージ（linux/amd64 + linux/arm64）のビルド・プッシュと
 * 古いイメージの自動削除を行うJenkinsfile。
 * 週1回（日曜深夜）のcronトリガーで自動実行。急ぎの場合は手動実行も可能。
 *
 * マルチアーキ構成（Issue #821）:
 * - QEMU (tonistiigi/binfmt) による arm64 ノード上での amd64 エミュレーションビルド
 * - docker buildx による linux/amd64 + linux/arm64 同時ビルド
 * - ECR には image index（マニフェストリスト）として :latest / :build-<N> を push
 * - 利用側 Job（ecr-verify / all-phases など）は変更不要
 *
 * パラメータ（Job DSLで定義）:
 * - AWS_REGION: AWSリージョン（デフォルト: ap-northeast-1）
 * - ECR_REPOSITORY_NAME: ECRリポジトリ名（デフォルト: ai-workflow-agent）
 * - IMAGE_RETENTION_COUNT: 保持するイメージ世代数（デフォルト: 2）
 *
 * 前提条件（ec2-fleet-medium ノード）:
 * - docker 19.03+（buildx 対応）
 * - docker run --privileged が許可されていること（binfmt 登録のため）
 * - amazon-ecr-credential-helper (docker-credential-ecr-login) がインストール済み（Issue #815 と統一）
 * - ECR への push 権限（EC2 インスタンスプロファイル）
 *
 * ノート:
 * - QEMU エミュレーションによりビルド時間が増加する（許容済み）
 * - AWS_ACCOUNT_ID は AWS STS (get-caller-identity) から自動取得
 * - AWS 認証は EC2 インスタンスプロファイルを使用
 *
 * 検証手順: jenkins/jobs/pipeline/ai-workflow/ecr-build/VERIFY_MULTIARCH.md を参照
 */

pipeline {
    agent {
        label 'ec2-fleet-medium'
    }

    triggers {
        cron('H 2 * * 0')
    }

    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 60, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        // AWS設定
        AWS_DEFAULT_REGION = "${params.AWS_REGION ?: 'ap-northeast-1'}"
        AWS_REGION_VALUE = "${params.AWS_REGION ?: 'ap-northeast-1'}"
        ECR_REPOSITORY_NAME_VALUE = "${params.ECR_REPOSITORY_NAME ?: 'ai-workflow-agent'}"
        IMAGE_RETENTION_COUNT_VALUE = "${params.IMAGE_RETENTION_COUNT ?: '2'}"
    }

    stages {
        stage('Validate Parameters') {
            steps {
                script {
                    echo "========================================="
                    echo "AI Workflow - ECR Image Build & Push"
                    echo "========================================="

                    String accountId = ''
                    try {
                        echo "AWS STSからアカウントIDを取得中..."
                        accountId = sh(
                            script: "aws sts get-caller-identity --query Account --output text",
                            returnStdout: true
                        ).trim()
                    } catch (Exception e) {
                        error("AWS STSからアカウントIDの取得に失敗しました。インスタンスプロファイルのIAM設定を確認してください。")
                    }

                    if (!accountId) {
                        error("AWS STSからアカウントIDの取得に失敗しました。インスタンスプロファイルのIAM設定を確認してください。")
                    }

                    def retentionCount = env.IMAGE_RETENTION_COUNT_VALUE?.trim() ?: '2'
                    try {
                        def count = retentionCount.toInteger()
                        if (count < 1) {
                            error("IMAGE_RETENTION_COUNT は1以上の整数を指定してください。指定値: ${retentionCount}")
                        }
                    } catch (NumberFormatException e) {
                        error("IMAGE_RETENTION_COUNT は整数を指定してください。指定値: ${retentionCount}")
                    }

                    env.AWS_ACCOUNT_ID_VALUE = accountId
                    env.ECR_REGISTRY = "${accountId}.dkr.ecr.${env.AWS_REGION_VALUE}.amazonaws.com"
                    env.ECR_IMAGE_NAME = "${env.ECR_REGISTRY}/${env.ECR_REPOSITORY_NAME_VALUE}"

                    currentBuild.description = "ECR Build | ${env.ECR_REPOSITORY_NAME_VALUE} | ${env.AWS_REGION_VALUE}"

                    echo "AWS Account ID: ${env.AWS_ACCOUNT_ID_VALUE}"
                    echo "AWS Region: ${env.AWS_REGION_VALUE}"
                    echo "ECR Repository: ${env.ECR_REPOSITORY_NAME_VALUE}"
                    echo "Image Retention Count: ${env.IMAGE_RETENTION_COUNT_VALUE}"
                    echo "ECR Registry: ${env.ECR_REGISTRY}"
                    echo "Build Number: ${env.BUILD_NUMBER}"
                }
            }
        }

        stage('Setup QEMU') {
            steps {
                script {
                    echo "========================================="
                    echo "Stage: Setup QEMU (binfmt)"
                    echo "========================================="

                    def qemuResult = sh(
                        script: """
                            docker run --privileged --rm tonistiigi/binfmt:qemu-v8.1.5 --install all
                        """,
                        returnStatus: true
                    )

                    if (qemuResult != 0) {
                        error("QEMU binfmt の登録に失敗しました。`docker run --privileged` が許可されているか確認してください。")
                    }

                    echo "QEMU binfmt の登録に成功しました"
                }
            }
        }

        stage('Setup Buildx') {
            steps {
                script {
                    echo "========================================="
                    echo "Stage: Setup Buildx"
                    echo "========================================="

                    def buildxVersionResult = sh(
                        script: "docker buildx version",
                        returnStatus: true
                    )

                    if (buildxVersionResult != 0) {
                        error("docker buildx が利用できません。Docker 19.03 以降がインストールされているか確認してください。")
                    }

                    def builderResult = sh(
                        script: """
                            docker buildx create --name multiarch-builder --use --bootstrap \
                            || docker buildx use multiarch-builder
                        """,
                        returnStatus: true
                    )

                    if (builderResult != 0) {
                        error("buildx builder の作成/切り替えに失敗しました。buildx の状態を確認してください。")
                    }

                    sh "docker buildx inspect --bootstrap"
                }
            }
        }

        stage('Verify ECR Credential Helper') {
            steps {
                script {
                    echo "========================================="
                    echo "Stage: Verify ECR Credential Helper"
                    echo "========================================="
                    echo "amazon-ecr-credential-helper による自動認証を使用（Issue #815 と統一）"

                    def helperResult = sh(
                        script: "docker-credential-ecr-login version",
                        returnStatus: true
                    )

                    if (helperResult != 0) {
                        error("docker-credential-ecr-login が見つかりません。ノードに amazon-ecr-credential-helper をインストールしてください。")
                    }

                    // リポジトリへの到達性も併せて確認
                    def verifyResult = sh(
                        script: """
                            aws ecr describe-repositories \
                                --repository-names ${env.ECR_REPOSITORY_NAME_VALUE} \
                                --region ${env.AWS_REGION_VALUE} \
                                --query 'repositories[0].repositoryUri' \
                                --output text
                        """,
                        returnStatus: true
                    )

                    if (verifyResult != 0) {
                        error("ECRリポジトリへのアクセスに失敗しました。IAM設定を確認してください。リージョン: ${env.AWS_REGION_VALUE}, リポジトリ: ${env.ECR_REPOSITORY_NAME_VALUE}")
                    }

                    echo "ECR credential helper 検出済み（buildx push 時に自動認証されます）"
                }
            }
        }

        stage('Docker Buildx Build & Push') {
            steps {
                script {
                    echo "========================================="
                    echo "Stage: Docker Buildx Build & Push"
                    echo "========================================="

                    echo "Building multi-arch Docker image: ${env.ECR_IMAGE_NAME}"
                    echo "Platforms: linux/amd64, linux/arm64"
                    echo "Tags: latest, build-${env.BUILD_NUMBER}"

                    sh """
                        docker buildx build \
                            --builder multiarch-builder \
                            --platform linux/amd64,linux/arm64 \
                            -t ${env.ECR_IMAGE_NAME}:latest \
                            -t ${env.ECR_IMAGE_NAME}:build-${env.BUILD_NUMBER} \
                            --push \
                            .
                    """

                    echo "Docker buildx build & push completed successfully"
                    echo "Pushed images:"
                    echo "  - ${env.ECR_IMAGE_NAME}:latest (multi-arch)"
                    echo "  - ${env.ECR_IMAGE_NAME}:build-${env.BUILD_NUMBER} (multi-arch)"

                    sh """
                        aws ecr describe-images \
                            --repository-name ${env.ECR_REPOSITORY_NAME_VALUE} \
                            --region ${env.AWS_REGION_VALUE} \
                            --image-ids imageTag=build-${env.BUILD_NUMBER} \
                            --query 'imageDetails[0].{digest:imageDigest,tags:imageTags,pushedAt:imagePushedAt}' \
                            --output table \
                        || echo "Warning: Could not retrieve image details"
                    """

                    sh """
                        echo "Inspecting manifest for latest tag..."
                        docker manifest inspect ${env.ECR_IMAGE_NAME}:latest \
                        || echo "Warning: Could not inspect manifest for latest tag"
                    """

                    sh """
                        echo "Inspecting manifest for build-${env.BUILD_NUMBER} tag..."
                        docker manifest inspect ${env.ECR_IMAGE_NAME}:build-${env.BUILD_NUMBER} \
                        || echo "Warning: Could not inspect manifest for build-${env.BUILD_NUMBER} tag"
                    """
                }
            }
        }

        stage('Cleanup Old Images') {
            steps {
                script {
                    echo "========================================="
                    echo "Stage: Cleanup Old Images"
                    echo "========================================="

                    def retentionCount = env.IMAGE_RETENTION_COUNT_VALUE.toInteger()

                    echo "Applying ECR lifecycle policy (retain latest ${retentionCount} images)..."

                    def policyJson = """
                    {
                        "rules": [
                            {
                                "rulePriority": 1,
                                "description": "最新${retentionCount}世代のみ保持",
                                "selection": {
                                    "tagStatus": "any",
                                    "countType": "imageCountMoreThan",
                                    "countNumber": ${retentionCount}
                                },
                                "action": {
                                    "type": "expire"
                                }
                            }
                        ]
                    }
                    """

                    def policyResult = sh(
                        script: """
                            aws ecr put-lifecycle-policy \
                                --repository-name ${env.ECR_REPOSITORY_NAME_VALUE} \
                                --region ${env.AWS_REGION_VALUE} \
                                --lifecycle-policy-text '${policyJson.replaceAll("'", "'\\\\''").trim()}'
                        """,
                        returnStatus: true
                    )

                    if (policyResult == 0) {
                        echo "ECRライフサイクルポリシーの適用に成功しました"
                        sh """
                            aws ecr get-lifecycle-policy \
                                --repository-name ${env.ECR_REPOSITORY_NAME_VALUE} \
                                --region ${env.AWS_REGION_VALUE} \
                                --query 'lifecyclePolicyText' \
                                --output text \
                            | python3 -m json.tool 2>/dev/null \
                            || echo "Policy applied (details not parseable)"
                        """
                    } else {
                        echo "WARNING: ライフサイクルポリシーの適用に失敗しました。手動削除にフォールバックします。"

                        sh """
                            echo "Fetching image list..."
                            IMAGES=\$(aws ecr describe-images \
                                --repository-name ${env.ECR_REPOSITORY_NAME_VALUE} \
                                --region ${env.AWS_REGION_VALUE} \
                                --query 'sort_by(imageDetails, &imagePushedAt)[].imageDigest' \
                                --output text)

                            TOTAL=\$(echo "\${IMAGES}" | wc -w)
                            KEEP=${retentionCount}

                            echo "Total images: \${TOTAL}, Keeping: \${KEEP}"

                            if [ "\${TOTAL}" -le "\${KEEP}" ]; then
                                echo "削除対象のイメージはありません（現在 \${TOTAL} 個、保持数 \${KEEP} 個）"
                            else
                                DELETE_COUNT=\$((TOTAL - KEEP))
                                echo "Deleting \${DELETE_COUNT} old image(s)..."

                                DELETE_DIGESTS=\$(echo "\${IMAGES}" | tr ' ' '\n' | head -n \${DELETE_COUNT})

                                for DIGEST in \${DELETE_DIGESTS}; do
                                    echo "Deleting image: \${DIGEST}"
                                    aws ecr batch-delete-image \
                                        --repository-name ${env.ECR_REPOSITORY_NAME_VALUE} \
                                        --region ${env.AWS_REGION_VALUE} \
                                        --image-ids imageDigest=\${DIGEST} \
                                    || echo "Warning: Failed to delete image \${DIGEST}"
                                done

                                echo "Old images cleanup completed"
                            fi
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                echo "========================================="
                echo "Post Processing: Cleanup"
                echo "========================================="

                echo "buildx --push 構成のためローカルイメージの削除は不要です"

                sh "docker buildx prune -f --keep-storage 5GB || true"

                echo "Build result: ${currentBuild.currentResult}"
            }
        }

        success {
            script {
                echo "========================================="
                echo "ECR Image Build & Push - SUCCESS"
                echo "========================================="
                echo "Repository: ${env.ECR_REPOSITORY_NAME_VALUE}"
                echo "Tags pushed: latest, build-${env.BUILD_NUMBER}"
                echo "Registry: ${env.ECR_REGISTRY}"
            }
        }

        failure {
            script {
                echo "========================================="
                echo "ECR Image Build & Push - FAILURE"
                echo "========================================="
                echo "Repository: ${env.ECR_REPOSITORY_NAME_VALUE}"
                echo "Build Number: ${env.BUILD_NUMBER}"
                echo "Please check the build logs for error details."
            }
        }
    }
}
